<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Quản trị Nông sản sạch</title>
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/Admin/css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
</head>

<body class="sb-nav-fixed">
    <!-- Top Navbar -->
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">
        <!-- Logo -->
        <a class="navbar-brand ps-3" asp-area="Dashboard" asp-controller="Home" asp-action="Index">Nông sản sạch</a>
        <!-- Toggle -->
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-4 me-lg-0" id="sidebarToggle"><i class="fas fa-bars"></i></button>

        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" id="navbarDropdown" role="button" data-bs-toggle="dropdown">
                    <i class="fas fa-user fa-fw"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                    <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index">Trang người dùng</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="dropdown-item">
                            <button type="submit" class="btn btn-link text-start p-0">Đăng xuất</button>
                        </form>
                    </li>
                </ul>
            </li>
        </ul>
    </nav>

    <div id="layoutSidenav">
        <!-- Sidebar -->
        <div id="layoutSidenav_nav">
            <nav class="sb-sidenav accordion sb-sidenav-dark" id="sidenavAccordion">
                <div class="sb-sidenav-menu">
                    <div class="nav">
                        <div class="sb-sidenav-menu-heading">Chức năng chính</div>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Home" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-tachometer-alt"></i></div>
                            Bảng điều khiển
                        </a>

                        <div class="sb-sidenav-menu-heading">Quản lý</div>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Categories" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-list"></i></div>
                            Danh mục
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Products" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-apple-alt"></i></div>
                            Sản phẩm
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="BatchLots" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-seedling"></i></div>
                            Lô hàng
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Orders" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-shopping-cart"></i></div>
                            Đơn hàng
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Customers" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-users"></i></div>
                            Khách hàng
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Coupons" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-ticket-alt"></i></div>
                            Mã giảm giá
                        </a>

                        <a class="nav-link" asp-area="Dashboard" asp-controller="Reports" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-chart-line"></i></div>
                            Báo cáo
                        </a>

                        <div class="sb-sidenav-menu-heading">Khác</div>
                        <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                            <div class="sb-nav-link-icon"><i class="fas fa-globe"></i></div>
                            Trang người dùng
                        </a>
                    </div>
                </div>

                <div class="sb-sidenav-footer">
                    <div class="small">Đăng nhập với quyền:</div>
                    @User.Identity?.Name
                </div>
            </nav>
        </div>

        <!-- Nội dung chính -->
        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4 py-3">
                    <h1 class="h3 mb-3 text-primary">@ViewData["Title"]</h1>
                    @RenderBody()
                </div>
            </main>

            <footer class="py-3 bg-light mt-auto border-top">
                <div class="container-fluid px-4">
                    <div class="d-flex justify-content-between small text-muted">
                        <div>© 2025 Nông sản sạch Dashboard</div>
                        <div><a href="#">Chính sách</a> · <a href="#">Điều khoản</a></div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Admin/js/scripts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

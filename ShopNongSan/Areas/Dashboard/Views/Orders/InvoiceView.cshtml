@model ShopNongSan.Models.Order
@using ShopNongSan.Models

@{
    ViewData["Title"] = $"Hóa đơn #{Model.Id}";
    var subtotal = Model.Items.Sum(i => i.UnitPrice * i.Quantity);
    var total = subtotal - Model.DiscountAmount;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success">
            <i class="fa fa-file-invoice"></i> HÓA ĐƠN #@Model.Id
        </h2>

        <a class="btn btn-sm btn-primary"
           asp-action="InvoicePdf"
           asp-route-id="@Model.Id">
            <i class="fa fa-file-pdf"></i> Xuất PDF
        </a>
    </div>


    <!-- Thông tin cửa hàng -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="fw-bold mb-2">NÔNG SẢN SẠCH</h5>
            <p class="mb-1">Địa chỉ: 123 Đường ABC, Quận 1, TP. Hồ Chí Minh</p>
            <p class="mb-1">Hotline: 0900 123 456</p>
            <p class="mb-1">Email: support@nongsansach.vn</p>
        </div>
    </div>

    <!-- Thông tin khách hàng -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light"><strong>Thông tin khách hàng</strong></div>
        <div class="card-body">
            <p><strong>Họ tên:</strong> @Model.CustomerName</p>
            <p><strong>Số điện thoại:</strong> @Model.Phone</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Địa chỉ:</strong> @Model.Address</p>
            <p><strong>Ngày đặt:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <!-- Chi tiết sản phẩm -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light"><strong>Chi tiết đơn hàng</strong></div>

        <div class="table-responsive">
            <table class="table table-striped table-bordered align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Product.Name</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end">@String.Format("{0:N0} đ", item.UnitPrice)</td>
                            <td class="text-end fw-bold">@String.Format("{0:N0} đ", item.UnitPrice * item.Quantity)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tổng tiền -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light"><strong>Thanh toán</strong></div>
        <div class="card-body">

            <div class="d-flex justify-content-between mb-2">
                <span>Tạm tính:</span>
                <span>@String.Format("{0:N0} đ", subtotal)</span>
            </div>

            <div class="d-flex justify-content-between mb-2">
                <span>Giảm giá:</span>
                <span class="text-success">-@String.Format("{0:N0} đ", Model.DiscountAmount)</span>
            </div>

            <hr />

            <div class="d-flex justify-content-between fw-bold">
                <span>Tổng thanh toán:</span>
                <span class="text-danger">@String.Format("{0:N0} đ", total)</span>
            </div>
        </div>
    </div>

    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left"></i> Quay lại
    </a>
</div>

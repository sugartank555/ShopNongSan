@using ShopNongSan.Models
@model IEnumerable<Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<!-- 🔥 HÀM CHUYỂN ENUM → TIẾNG VIỆT -->
@functions {
    string GetStatusText(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "Chờ xử lý",
            OrderStatus.Paid => "Đã thanh toán",
            OrderStatus.Processing => "Đang xử lý",
            OrderStatus.Shipped => "Đang giao hàng",
            OrderStatus.Completed => "Hoàn thành",
            OrderStatus.Cancelled => "Đã hủy",
            OrderStatus.Refunded => "Đã hoàn tiền",
            _ => "Không xác định"
        };
    }

    string GetStatusBadge(OrderStatus status)
    {
        return status switch
        {
            OrderStatus.Pending => "bg-warning text-dark",
            OrderStatus.Paid => "bg-success",
            OrderStatus.Processing => "bg-primary",
            OrderStatus.Shipped => "bg-info text-dark",
            OrderStatus.Completed => "bg-success",
            OrderStatus.Cancelled => "bg-danger",
            OrderStatus.Refunded => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success">
        <i class="fas fa-box"></i> Quản lý đơn hàng
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- 🔥 TAB LỌC TRẠNG THÁI -->
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-secondary @(ViewBag.CurrentStatus == null ? "active" : "")">
            Tất cả
        </a>

        @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
        {
            <a asp-action="Index"
               asp-route-status="@s"
               class="btn btn-outline-success @(ViewBag.CurrentStatus?.ToString() == s.ToString() ? "active" : "")">

                @GetStatusText(s)
            </a>
        }
    </div>

    <!-- 🔥 BẢNG ĐƠN HÀNG -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover mb-0 align-middle">
                <thead class="table-success text-center">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Ngày đặt</th>
                        <th>Tổng sau giảm</th>
                        <th>Trạng thái</th>
                        <th width="180"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold">#@o.Id</td>

                            <td>
                                <div>@o.CustomerName</div>
                                <small class="text-muted">@o.Email</small>
                            </td>

                            <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>

                            <td class="text-end">@String.Format("{0:N0} đ", o.Total)</td>

                            <!-- 🔥 Badge trạng thái -->
                            <td class="text-center">
                                <span class="badge @GetStatusBadge(o.Status)">
                                    @GetStatusText(o.Status)
                                </span>
                            </td>

                            <!-- 🔥 Nút xem + dropdown -->
                            <td class="text-center">

                                <!-- Xem chi tiết -->
                                <a asp-action="Details" asp-route-id="@o.Id"
                                   class="btn btn-sm btn-outline-success me-1">
                                    <i class="fas fa-eye"></i>
                                </a>

                                <!-- DROPDOWN CẬP NHẬT TRẠNG THÁI -->
                                <form asp-action="UpdateStatus" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@o.Id" />

                                    <select name="status"
                                            class="form-select form-select-sm d-inline-block"
                                            onchange="this.form.submit()"
                                            style="width:140px">

                                        @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                                        {
                                            <option value="@s"
                                                    selected="@(o.Status == s)">
                                                @GetStatusText(s)
                                            </option>
                                        }

                                    </select>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

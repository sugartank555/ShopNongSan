@model ShopNongSan.Models.Coupon
@{
   
    ViewData["Title"] = "Thêm mã giảm giá";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success"><i class="fas fa-plus-circle"></i> Thêm mã giảm giá</h2>

    <form asp-action="Create" method="post" class="card shadow-sm p-4">
        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DiscountType" class="form-label"></label>
                <select asp-for="DiscountType" class="form-select">
                    <option value="Percent">Giảm theo phần trăm</option>
                    <option value="Fixed">Giảm theo số tiền</option>
                </select>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="DiscountValue" class="form-label"></label>
                <input asp-for="DiscountValue" type="number" step="0.01" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ExpiryDate" class="form-label"></label>
                <input asp-for="ExpiryDate" type="date" class="form-control" />
            </div>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Kích hoạt ngay</label>
        </div>

        <div>
            <button class="btn btn-success"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

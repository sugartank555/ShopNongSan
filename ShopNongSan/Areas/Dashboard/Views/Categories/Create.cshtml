@model ShopNongSan.Models.Category
@{
   
    ViewData["Title"] = "Thêm danh mục";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success"><i class="fas fa-plus-circle"></i> Thêm danh mục mới</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="card shadow-sm p-4">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label">Ảnh đại diện</label>
            <input type="file" name="imageFile" class="form-control" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
        </div>
        <div>
            <button class="btn btn-success"><i class="fas fa-save"></i> Lưu</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model ShopNongSan.Models.BatchLot
@{
    ViewData["Title"] = "Thêm lô hàng";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success"><i class="fas fa-plus-circle"></i> Thêm lô hàng mới</h2>

    <form asp-action="Create" method="post" class="card shadow-sm p-4 border-0">
        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="LotCode" class="form-label">Mã lô</label>
                <input asp-for="LotCode" class="form-control" />
                <span asp-validation-for="LotCode" class="text-danger small"></span>
            </div>
            <div class="col-md-8 mb-3">
                <label asp-for="FarmName" class="form-label">Tên nông trại</label>
                <input asp-for="FarmName" class="form-control" />
                <span asp-validation-for="FarmName" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="ProductId" class="form-label">Sản phẩm</label>
                <select asp-for="ProductId" asp-items="@(new SelectList(ViewBag.Products, "Id", "Name"))" class="form-select">
                    <option value="">-- Chọn sản phẩm --</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="HarvestDate" class="form-label">Ngày thu hoạch</label>
                <input asp-for="HarvestDate" type="date" class="form-control" />
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="ExpireDate" class="form-label">Ngày hết hạn</label>
                <input asp-for="ExpireDate" type="date" class="form-control" />
                <span asp-validation-for="ExpireDate" class="text-danger small"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <label asp-for="QuantityIn" class="form-label">Số lượng nhập</label>
                <input asp-for="QuantityIn" class="form-control" />
            </div>
            <div class="col-md-3 mb-3">
                <label asp-for="QuantitySold" class="form-label">Đã bán</label>
                <input asp-for="QuantitySold" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Certification" class="form-label">Chứng nhận (nếu có)</label>
                <input asp-for="Certification" class="form-control" />
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <a asp-action="Index" class="btn btn-secondary me-2">Quay lại</a>
            <button type="submit" class="btn btn-success px-4"><i class="fas fa-save"></i> Lưu</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model IEnumerable<ShopNongSan.Models.Product>
@{
  
    ViewData["Title"] = "";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success"><i class="fas fa-box"></i> Quản lý sản phẩm</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <a asp-action="Create" class="btn btn-primary mb-3">
        <i class="fas fa-plus"></i> Thêm sản phẩm
    </a>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-success text-center">
                    <tr>
                        <th>Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Trạng thái</th>
                        <th style="width: 150px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "/images/noimg.png")"
                                     style="width:70px;height:70px;object-fit:cover;border-radius:8px;" />
                            </td>
                            <td>@p.Name</td>
                            <td>@p.Category?.Name</td>
                            <td class="text-end">@String.Format("{0:N0} đ", p.Price)</td>
                            <td class="text-center">
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngừng bán</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning me-1">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Xóa sản phẩm @p.Name ?');">
                                    <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

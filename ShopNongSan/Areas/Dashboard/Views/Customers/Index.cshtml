@model IEnumerable<ShopNongSan.Areas.Dashboard.Controllers.CustomerViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="container-fluid px-4">
    <h2 class="mt-4 mb-3 text-success"><i class="fas fa-users"></i> Quản lý người dùng</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bộ lọc -->
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input name="search" value="@ViewBag.Search" class="form-control" placeholder="🔍 Tìm theo email hoặc tên..." />
        </div>
        <div class="col-md-3">
            <select name="role" class="form-select">
                <option>Tất cả</option>
                @foreach (var r in ViewBag.Roles)
                {
                    <option value="@r" selected="@(ViewBag.RoleFilter == r ? "selected" : null)">@r</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-success w-100"><i class="fas fa-filter"></i> Lọc</button>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-success text-center">
                    <tr>
                        <th>Email</th>
                        <th>Tên đăng nhập</th>
                        <th>Quyền</th>
                        <th>Xác nhận</th>
                        <th>Trạng thái</th>
                        <th style="width:180px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.Email</td>
                            <td>@u.UserName</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(u.Roles))
                                {
                                    <span class="badge bg-info text-dark">@u.Roles</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Chưa có quyền</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (u.IsEmailConfirmed)
                                {
                                    <span class="badge bg-success">Đã xác nhận</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chưa xác nhận</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (u.IsLocked)
                                {
                                    <span class="badge bg-danger">Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (u.IsLocked)
                                {
                                    <form asp-action="Unlock" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button class="btn btn-sm btn-success"><i class="fas fa-lock-open"></i></button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Lock" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button class="btn btn-sm btn-warning"><i class="fas fa-lock"></i></button>
                                    </form>
                                }

                                <form asp-action="ChangeRole" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <select name="newRole" class="form-select form-select-sm d-inline w-auto">
                                        @foreach (var r in ViewBag.Roles)
                                        {
                                            <option>@r</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-primary"><i class="fas fa-user-shield"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Phân trang -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?page=@i&search=@ViewBag.Search&role=@ViewBag.RoleFilter">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

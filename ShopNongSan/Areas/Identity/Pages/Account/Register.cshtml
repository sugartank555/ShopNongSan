@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Nông Sản Sạch</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #b3e5c3, #f0fff4);
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
        }

        .register-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            overflow: hidden;
            animation: fadeInUp 0.8s ease;
        }

        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .register-header {
            background-color: #28a745;
            color: white;
            text-align: center;
            padding: 20px;
        }

        .form-floating > label {
            color: #6c757d;
        }

        .btn-primary {
            background-color: #28a745;
            border: none;
        }

            .btn-primary:hover {
                background-color: #218838;
            }

        .text-muted a {
            color: #198754;
            text-decoration: none;
            font-weight: 500;
        }

            .text-muted a:hover {
                text-decoration: underline;
            }
    </style>

</head>
<body>

    <div class="register-card">
        <div class="register-header">
            <h3 class="fw-bold mb-0"><i class="fa-solid fa-leaf me-2"></i>Đăng ký tài khoản</h3>
            <p class="mb-0 small text-light">Tham gia Nông Sản Sạch ngay hôm nay!</p>
        </div>
        <div class="p-4">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email"><i class="fa-solid fa-envelope me-2 text-success"></i>Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="password" />
                    <label asp-for="Input.Password"><i class="fa-solid fa-lock me-2 text-success"></i>Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword"><i class="fa-solid fa-key me-2 text-success"></i>Xác nhận mật khẩu</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                    <i class="fa-solid fa-user-plus me-1"></i> Đăng ký
                </button>
            </form>

            <div class="text-center mt-3 text-muted">
                Đã có tài khoản?
                <a asp-page="/Account/Login">Đăng nhập ngay</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>

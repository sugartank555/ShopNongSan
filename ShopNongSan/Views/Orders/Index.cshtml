@using ShopNongSan.Models
@model IEnumerable<Order>

@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Đơn hàng của tôi</h2>
            <p class="text-muted mb-0">Theo dõi trạng thái và chi tiết các đơn đã đặt.</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Bạn chưa có đơn hàng nào.
            <a asp-controller="Shop" asp-action="Index" class="fw-semibold text-success">Mua sắm ngay</a>.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Người nhận</th>
                                <th class="text-end">Tổng (sau giảm)</th>
                                <th class="text-end">Giảm giá</th>
                                <th>Trạng thái</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var o in Model)
                            {
                                string statusClass = "bg-light text-dark";
                                string statusText = "Không xác định";

                                switch (o.Status)
                                {
                                    case OrderStatus.Pending:
                                        statusClass = "bg-secondary";
                                        statusText = "Chờ xác nhận";
                                        break;

                                    case OrderStatus.Processing:
                                        statusClass = "bg-info";
                                        statusText = "Đang xử lý";
                                        break;

                                    case OrderStatus.Paid:   // 🟢 Nếu bạn có trạng thái Paid
                                        statusClass = "bg-success";
                                        statusText = "Đã thanh toán";
                                        break;

                                    case OrderStatus.Shipped:
                                        statusClass = "bg-primary";
                                        statusText = "Đang giao hàng";
                                        break;

                                    case OrderStatus.Completed:
                                        statusClass = "bg-success";
                                        statusText = "Hoàn thành";
                                        break;

                                    case OrderStatus.Cancelled:
                                        statusClass = "bg-danger";
                                        statusText = "Đã hủy";
                                        break;
                                }

                                <tr>
                                    <td>#@o.Id</td>
                                    <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(string.IsNullOrEmpty(o.CustomerName) ? "—" : o.CustomerName)</td>

                                    <td class="text-end text-danger fw-semibold">
                                        @String.Format("{0:N0} đ", o.Total)
                                    </td>

                                    <td class="text-end">
                                        @if (o.DiscountAmount > 0)
                                        {
                                            <span class="text-success">-@String.Format("{0:N0} đ", o.DiscountAmount)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0 đ</span>
                                        }
                                    </td>

                                    <td>
                                        <span class="badge @statusClass">@statusText</span>
                                    </td>

                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@o.Id"
                                           class="btn btn-sm btn-outline-success">
                                            Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

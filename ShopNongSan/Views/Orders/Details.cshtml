@using ShopNongSan.Models
@model Order

@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Id}";

    var subtotal = Model.Items?.Sum(i => i.UnitPrice * i.Quantity) ?? 0m;

    string statusClass = "";
    string statusText = "";

    switch (Model.Status)
    {
        case OrderStatus.Pending:
            statusClass = "bg-secondary";
            statusText = "Chờ xác nhận";
            break;
        case OrderStatus.Processing:
            statusClass = "bg-info";
            statusText = "Đang xử lý";
            break;
        case OrderStatus.Shipped:
            statusClass = "bg-primary";
            statusText = "Đang giao hàng";
            break;
        case OrderStatus.Completed:
            statusClass = "bg-success";
            statusText = "Hoàn thành";
            break;
        case OrderStatus.Cancelled:
            statusClass = "bg-danger";
            statusText = "Đã hủy";
            break;
        default:
            statusClass = "bg-light text-dark";
            statusText = Model.Status.ToString();
            break;
        case OrderStatus.Paid:
            statusClass = "bg-success";
            statusText = "Đã thanh toán";
            break;

    }

    // Mapping status → bước timeline
    int currentStep = Model.Status switch
    {
        OrderStatus.Pending => 1,
        OrderStatus.Processing => 2,
        OrderStatus.Shipped => 3,
        OrderStatus.Completed => 4,
        OrderStatus.Cancelled => -1,
        _ => 1
    };

    var steps = new[]
    {
        new { Id = 1, Title = "Đã đặt hàng", Icon = "fa-file-alt" },
        new { Id = 2, Title = "Đang xử lý", Icon = "fa-cogs" },
        new { Id = 3, Title = "Đang giao hàng", Icon = "fa-truck" },
        new { Id = 4, Title = "Đã giao xong", Icon = "fa-check-circle" }
    };
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Chi tiết đơn hàng #@Model.Id</h2>
            <p class="text-muted mb-0">
                Đặt lúc @Model.CreatedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
            </p>
        </div>
        <span class="badge @statusClass px-3 py-2">@statusText</span>
    </div>

    <!-- 🔥 TIMELINE TRẠNG THÁI ĐƠN HÀNG -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light">
            <strong>Trạng thái đơn hàng</strong>
        </div>

        <div class="card-body">

            @if (Model.Status == OrderStatus.Cancelled)
            {
                <div class="text-center py-4">
                    <i class="fa fa-times-circle text-danger" style="font-size:60px;"></i>
                    <h4 class="mt-3 text-danger fw-bold">Đơn hàng đã bị hủy</h4>
                    <p class="text-muted">Bạn có thể liên hệ hỗ trợ nếu cần thêm thông tin.</p>
                </div>
            }
            else
            {
                <div class="order-tracking d-flex justify-content-between position-relative px-2">

                    @foreach (var step in steps)
                    {
                        bool isActive = step.Id <= currentStep;

                        <div class="step text-center flex-fill">
                            <div class="icon-wrapper mb-2 @(isActive ? "active" : "")">
                                <i class="fa @step.Icon"></i>
                            </div>
                            <p class="small @(isActive ? "fw-bold text-success" : "text-muted")">
                                @step.Title
                            </p>
                        </div>
                    }

                    <div class="step-line"></div>
                </div>
            }

        </div>
    </div>
    <!-- END TIMELINE -->

    <div class="row g-4">

        <!-- Thông tin giao hàng -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-success text-white">
                    <strong>Thông tin giao hàng</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Người nhận:</strong> @Model.CustomerName</p>
                    <p class="mb-1"><strong>Số điện thoại:</strong> @Model.Phone</p>
                    <p class="mb-1"><strong>Email:</strong> @(Model.Email ?? "—")</p>
                    <p class="mb-0"><strong>Địa chỉ:</strong> @Model.Address</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light">
                    <strong>Thông tin thanh toán</strong>
                </div>
                <div class="card-body">

                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính</span>
                        <span>@($"{subtotal:N0} đ")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span>Giảm giá</span>
                        <span class="text-success">-@($"{Model.DiscountAmount:N0} đ")</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <strong>Tổng thanh toán</strong>
                        <strong class="text-danger">@($"{Model.Total:N0} đ")</strong>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.CouponCode))
                    {
                        <p class="mt-2 mb-0 text-muted">Mã giảm giá: <strong>@Model.CouponCode</strong></p>
                    }
                </div>
            </div>
        </div>

        <!-- Sản phẩm -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <strong>Sản phẩm trong đơn</strong>
                    <span class="text-muted small">@Model.Items?.Count() sản phẩm</span>
                </div>
                <div class="card-body p-0">

                    @if (Model.Items == null || !Model.Items.Any())
                    {
                        <div class="p-3 text-muted">Không có sản phẩm nào trong đơn.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th class="text-center">SL</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var i in Model.Items)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <img src="@(!string.IsNullOrEmpty(i.Product?.ImageUrl) ? i.Product.ImageUrl : "/images/noimg.png")"
                                                         class="me-2 rounded"
                                                         style="width:60px;height:60px;object-fit:cover" />

                                                    <div>
                                                        <div class="fw-semibold">@i.Product?.Name</div>
                                                        <div class="text-muted small">@i.Product?.Category?.Name</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">@i.Quantity</td>
                                            <td class="text-end">@($"{i.UnitPrice:N0} đ")</td>
                                            <td class="text-end fw-semibold">@($"{(i.UnitPrice * i.Quantity):N0} đ")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">&laquo; Quay lại danh sách</a>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-success ms-2">Tiếp tục mua sắm</a>
            </div>
        </div>

    </div>
</div>

<!-- TIMELINE CSS -->
<style>
    .order-tracking .step {
        position: relative;
        text-align: center;
        z-index: 2;
    }

    .order-tracking .icon-wrapper {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 2px solid #ccc;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fff;
        color: #999;
        font-size: 18px;
        transition: .3s;
        margin: auto;
    }

        .order-tracking .icon-wrapper.active {
            background: #28a745;
            border-color: #28a745;
            color: #fff;
            box-shadow: 0 0 10px rgba(40,167,69,.4);
        }

    .order-tracking .step-line {
        position: absolute;
        top: 24px;
        left: 10%;
        right: 10%;
        height: 4px;
        background: #e0e0e0;
        z-index: 1;
    }
</style>

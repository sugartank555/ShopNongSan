@model List<ShopNongSan.Controllers.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    var couponJson = ViewBag.Coupon as string;
    ShopNongSan.Models.Coupon? appliedCoupon = null;
    if (!string.IsNullOrEmpty(couponJson))
        appliedCoupon = System.Text.Json.JsonSerializer.Deserialize<ShopNongSan.Models.Coupon>(couponJson);
    decimal subtotal = Model.Sum(x => x.Total);
    decimal discount = appliedCoupon != null
        ? (appliedCoupon.DiscountType == "Percent"
            ? subtotal * appliedCoupon.DiscountValue / 100
            : appliedCoupon.DiscountValue)
        : 0;
    decimal total = subtotal - discount;
}

<div class="container py-5">
    <h2 class="mb-4 text-success"><i class="icon-shopping_cart"></i> Giỏ hàng</h2>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Chưa có sản phẩm nào trong giỏ hàng.</div>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-success">Tiếp tục mua sắm</a>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-bordered align-middle">
                <thead class="table-success text-center">
                    <tr>
                        <th>Ảnh</th>
                        <th>Sản phẩm</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in Model)
                    {
                        <tr>
                            <td style="width:90px">
                                <img src="@(!string.IsNullOrEmpty(i.Image) ? i.Image : "/images/noimg.png")"
                                     class="img-thumbnail" style="width:80px;height:80px;object-fit:cover" />
                            </td>
                            <td>@i.Name</td>
                            <td class="text-end">@String.Format("{0:N0} đ", i.Price)</td>
                            <td class="text-center" style="width:120px">
                                <form asp-action="Update" method="post" class="d-inline-flex">
                                    <input type="hidden" name="id" value="@i.ProductId" />
                                    <input type="number" name="qty" value="@i.Quantity" min="1"
                                           class="form-control form-control-sm text-center" style="width:70px" />
                                    <button class="btn btn-sm btn-outline-success ms-1"> Cập nhật<i class="fas fa-sync-alt"></i></button>
                                </form>
                            </td>
                            <td class="text-end">@String.Format("{0:N0} đ", i.Total)</td>
                            <td class="text-center">
                                <a asp-action="Remove" asp-route-id="@i.ProductId"
                                   class="btn btn-sm btn-danger">Xóa<i class="fas fa-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Tổng cộng -->
        <div class="row justify-content-end">
            <div class="col-md-5">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Tóm tắt đơn hàng</h5>

                        <div class="d-flex justify-content-between">
                            <span>Tạm tính:</span>
                            <span>@String.Format("{0:N0} đ", subtotal)</span>
                        </div>

                        @if (appliedCoupon != null)
                        {
                            <div class="d-flex justify-content-between text-success">
                                <span>Mã giảm: @appliedCoupon.Code</span>
                                <span>-@String.Format("{0:N0} đ", discount)</span>
                            </div>
                        }

                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Tổng cộng:</span>
                            <span class="text-success">@String.Format("{0:N0} đ", total)</span>
                        </div>

                        <!-- Nhập mã giảm giá -->
                        <form asp-action="ApplyCoupon" method="post" class="mt-3">
                            <div class="input-group">
                                <input type="text" name="code" placeholder="Nhập mã giảm giá..."
                                       class="form-control" />
                                <button class="btn btn-outline-success" type="submit">Áp dụng</button>
                            </div>
                        </form>

                        <div class="mt-4 d-flex justify-content-between">
                            <a asp-action="Clear" class="btn btn-outline-danger">
                                <i class="fas fa-trash-alt"></i> Xóa tất cả
                            </a>
                            <a asp-controller="Checkout" asp-action="Index"
                               class="btn btn-success px-4">Thanh toán</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

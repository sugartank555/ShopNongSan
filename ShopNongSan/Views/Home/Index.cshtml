@model IEnumerable<ShopNongSan.Models.Product>
@{
    ViewData["Title"] = "Nông Sản Sạch – Trang chủ";

    var categories = ViewBag.Categories as IEnumerable<ShopNongSan.Models.Category> ?? new List<ShopNongSan.Models.Category>();
    var featured = ViewBag.FeaturedProducts as IEnumerable<ShopNongSan.Models.Product> ?? new List<ShopNongSan.Models.Product>();
}

<!-- HERO -->
<section class="hero-wrap" style="background-image:url('/images/bg_1.jpg'); background-size:cover; background-position:center;">
    <div class="py-5 text-center text-white">
        <h1 class="fw-bold display-4 text-danger">Nông sản sạch</h1>
        <p class="lead mb-3">Tươi – Sạch – An toàn – Giao nhanh</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-success btn-lg shadow">
            <i class="fa fa-shopping-basket me-1"></i> Mua sắm ngay
        </a>
    </div>
</section>

<!-- CATEGORY -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Tất cả danh mục</h2>
            <p class="text-muted">Khám phá các sản phẩm nông sản sạch</p>
        </div>

        <div class="row g-4">
            @foreach (var c in categories)
            {
                var imgSrc = !string.IsNullOrEmpty(c.ImageUrl) ? c.ImageUrl : "/images/noimg.png";

                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm hover-zoom h-100 text-center">
                        <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@c.Id"
                           class="text-decoration-none text-dark">
                            <img src="@imgSrc"
                                 alt="@c.Name"
                                 class="card-img-top rounded-top"
                                 style="height:180px; object-fit:cover;" />
                            <div class="card-body">
                                <h6 class="fw-semibold">@c.Name</h6>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ALL PRODUCTS -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Danh mục nổi bật</h2>
            <p class="text-muted">Lựa chọn nhóm sản phẩm bạn quan tâm</p>
        </div>

        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm hover-zoom h-100">
                        <img src="@(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "/images/noimg.png")"
                             class="card-img-top" style="height:210px; object-fit:cover;" />

                        <div class="card-body d-flex flex-column">
                            <h6 class="fw-semibold mb-1">@p.Name</h6>

                            <strong class="text-danger mb-3" style="font-size:18px;">
                                @($"{p.Price:N0} đ")
                            </strong>

                            <!-- Nút xem chi tiết -->
                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id"
                               class="btn btn-outline-success w-100 mb-2"
                               style="border-radius: 30px; font-weight:600;">
                                Xem chi tiết
                            </a>

                            <!-- Nút thêm giỏ hàng -->
                            <form method="post" asp-controller="Cart" asp-action="Add" class="mt-auto">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-success w-100" style="border-radius: 30px;">
                                    <i class="fa fa-cart-plus me-1"></i> Thêm giỏ hàng
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- FEATURED PRODUCTS -->
@if (featured.Any())
{
    <section class="py-5 bg-light">
        <div class="container">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-success">Sản phẩm nổi bật</h2>
                <p class="text-muted">Lựa chọn hàng đầu từ khách hàng</p>
            </div>

            <div class="row g-4">
                @foreach (var p in featured)
                {
                    <div class="col-6 col-md-3">
                        <div class="card border-0 shadow-sm hover-zoom h-100">
                            <img src="@(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "/images/noimg.png")"
                                 class="card-img-top" style="height:210px; object-fit:cover;" />

                            <div class="card-body d-flex flex-column">
                                <h6>@p.Name</h6>
                                <strong class="text-success">@($"{p.Price:N0} đ")</strong>

                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id"
                                   class="btn btn-outline-success btn-sm mt-auto">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- NEW PRODUCTS -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Sản phẩm mới nhất</h2>
            <p class="text-muted">Các sản phẩm vừa nhập kho</p>
        </div>

        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm hover-zoom h-100">
                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@p.Id">
                            <img src="@(!string.IsNullOrEmpty(p.ImageUrl) ? p.ImageUrl : "/images/noimg.png")"
                                 class="card-img-top" style="height:210px; object-fit:cover;" />
                        </a>

                        <div class="card-body d-flex flex-column">
                            <h6>@p.Name</h6>
                            <strong class="text-success">@($"{p.Price:N0} đ")</strong>

                            <form method="post" asp-controller="Cart" asp-action="Add" class="mt-auto">
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" class="btn btn-success btn-sm w-100">
                                    <i class="fa fa-cart-plus"></i> Thêm giỏ hàng
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
